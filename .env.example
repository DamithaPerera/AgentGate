# Auth0 Configuration
# Generate with: openssl rand -hex 32
AUTH0_SECRET='your-32-char-random-secret'
AUTH0_BASE_URL='http://localhost:3000'
AUTH0_ISSUER_BASE_URL='https://YOUR_TENANT.auth0.com'
AUTH0_CLIENT_ID='your_auth0_client_id'
AUTH0_CLIENT_SECRET='your_auth0_client_secret'

# Auth0 Token Vault
AUTH0_TOKEN_VAULT_AUDIENCE='https://YOUR_TENANT.auth0.com/api/v2/'

# OpenRouter (free models available)
OPENROUTER_API_KEY='your_openrouter_api_key'
OPENROUTER_MODEL='deepseek/deepseek-chat-v3-0324:free'

# Upstash Redis (free tier)
UPSTASH_REDIS_REST_URL='https://your-redis.upstash.io'
UPSTASH_REDIS_REST_TOKEN='your_upstash_token'

# App URL
NEXT_PUBLIC_APP_URL='http://localhost:3000'

# Agent JWT signing secret (generate with: openssl rand -hex 32)
AGENT_JWT_SECRET='your-agent-jwt-signing-secret'
