# ─────────────────────────────────────────────────────────────
# AgentGate — Environment Variables
# Copy to .env.local for local dev
# Set in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Auth0 ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH0_SECRET='your-32-char-random-secret'
# LOCAL:  http://localhost:3000
# VERCEL: https://your-project.vercel.app
AUTH0_BASE_URL='http://localhost:3000'
AUTH0_ISSUER_BASE_URL='https://YOUR_TENANT.auth0.com'
AUTH0_CLIENT_ID='your_auth0_client_id'
AUTH0_CLIENT_SECRET='your_auth0_client_secret'

# ── Auth0 Token Vault ───────────────────────────────────────────
AUTH0_TOKEN_VAULT_AUDIENCE='https://YOUR_TENANT.auth0.com/api/v2/'

# ── Upstash Redis (free tier at upstash.com) ───────────────────
# Without these, AgentGate uses in-memory storage (resets on cold start)
UPSTASH_REDIS_REST_URL='https://your-redis.upstash.io'
UPSTASH_REDIS_REST_TOKEN='your_upstash_token'

# ── Public App URL ──────────────────────────────────────────────
# Vercel injects VERCEL_URL automatically; set this for a custom domain
# LOCAL:  http://localhost:3000
# VERCEL: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL='http://localhost:3000'

# ── Agent JWT signing secret ────────────────────────────────────
# Generate with: openssl rand -hex 32
AGENT_JWT_SECRET='your-agent-jwt-signing-secret'
